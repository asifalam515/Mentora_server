// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  TRANSFERRED
  REFUNDED
}

enum UserStatus {
  ACTIVE
  BANNED
}

enum Role {
  STUDENT
  TUTOR
  ADMIN
}

model User {
  id            String     @id @default(uuid())
  name          String
  email         String
  // password field for custom authentication 
  password      String
  
    role      Role   @default(STUDENT)
  emailVerified Boolean    @default(false)
  image         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
 
 
  status        UserStatus @default(ACTIVE)

  tutorProfile TutorProfile?
  bookings     Booking[]     @relation("StudentBookings")
  reviews      Review[]
  banReason  String?
  banned Boolean? @default(false)
  banExpires DateTime?
  stripeCustomerId String?

  @@unique([email])
  @@map("user")
}

model TutorProfile {
  id         String  @id @default(uuid())
  bio        String
  pricePerHr Float
  rating     Float   @default(0)
  experience Int
  isVerified Boolean @default(false)
  isFeatured Boolean @default(false)
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])
  stripeConnectedAccountId String?

  categories   TutorCategory[]
  bookings     Booking[]
  reviews      Review[]
  availability AvailabilitySlot[]

  createdAt DateTime @default(now())
}

model Category {
  id   String @id @default(uuid())
  name String @unique

  tutors TutorCategory[]
}

model TutorCategory {
  tutorId    String
  categoryId String

  tutor    TutorProfile @relation(fields: [tutorId], references: [id])
  category Category     @relation(fields: [categoryId], references: [id])

  @@id([tutorId, categoryId])
}

model AvailabilitySlot {
  id        String   @id @default(uuid())
  startTime DateTime
  endTime   DateTime
  isBooked  Boolean  @default(false)

  tutorId  String
  bookings Booking[]
  tutor    TutorProfile @relation(fields: [tutorId], references: [id])
  @@unique([tutorId, startTime])
  @@unique([tutorId, endTime])
}

model Booking {
  id     String        @id @default(uuid())
  status BookingStatus @default(PENDING)
  date   DateTime
  paymentStatus PaymentStatus @default(PENDING)
  totalHours Float @default(0)
  totalAmountCents Int @default(0)
  commissionAmountCents Int @default(0)
  tutorAmountCents Int @default(0)
  currency String @default("usd")
  stripePaymentIntentId String? @unique
  stripeChargeId String?
  stripeTransferId String?
  stripeRefundId String?

  studentId String
  tutorId   String
  slotId    String

  student User             @relation("StudentBookings", fields: [studentId], references: [id])
  tutor   TutorProfile     @relation(fields: [tutorId], references: [id])
  slot    AvailabilitySlot @relation(fields: [slotId], references: [id])

  review Review?

  createdAt DateTime @default(now())
}

model Review {
  id      String  @id @default(uuid())
  rating  Int
  comment String?

  studentId String
  tutorId   String
  bookingId String @unique

  student User         @relation(fields: [studentId], references: [id])
  tutor   TutorProfile @relation(fields: [tutorId], references: [id])
  booking Booking      @relation(fields: [bookingId], references: [id])

  createdAt DateTime @default(now())
}




